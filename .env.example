# ─── Supabase (required) ─────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── CloudConvert (required for format conversions) ───────────────────────────
# Word/Excel/PPT ↔ PDF conversions. Get key at: https://cloudconvert.com/dashboard/api/v2/keys
VITE_CLOUDCONVERT_API_KEY=your-cloudconvert-api-key

# ─── OCR.space (optional) ────────────────────────────────────────────────────
# Free tier: 500 req/day, 1MB limit. Get key at: https://ocr.space/ocrapi/freekey
# Leave empty to use the free demo key (rate-limited).
VITE_OCR_SPACE_API_KEY=

# ─── Supabase Edge Function secrets (set in Supabase dashboard, NOT here) ────
# Go to: https://app.supabase.com → Edge Functions → Manage secrets
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# CLOUDCONVERT_API_KEY=your-cloudconvert-api-key
