# ─── App URL (no trailing slash) ─────────────────────────────────────────────
# Change this to your custom domain when ready
VITE_APP_URL=https://yourdomain.com

# ─── Supabase (required) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Stripe (required for payments) ──────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_STARTER_YEARLY_PRICE_ID=price_...
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_...
VITE_STRIPE_TEAM_MONTHLY_PRICE_ID=price_...
VITE_STRIPE_TEAM_YEARLY_PRICE_ID=price_...

# ─── CloudConvert (required for Word/Excel/PPT conversions) ──────────────────
# Never commit your real key — use Supabase secrets in production
VITE_CLOUDCONVERT_API_KEY=

# ─── OCR.space (optional) ────────────────────────────────────────────────────
VITE_OCR_SPACE_API_KEY=
